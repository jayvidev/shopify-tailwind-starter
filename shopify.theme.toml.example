[environments.development]
store = "your-store.myshopify.com"
theme = "your-theme-id"
store-password = "your-store-password"

[environments.staging]
store = "your-store.myshopify.com"
theme = "your-theme-id"
ignore = ["templates/*", "config/*"]

[environments.production]
store = "your-store.myshopify.com"
theme = "your-theme-id"
ignore = ["templates/*", "config/*"]